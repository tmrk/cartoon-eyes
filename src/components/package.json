{
  "name": "cartoon-eyes",
  "version": "2.0.2",
  "description": "Dependency-free React component for customisable animated SVG cartoon eyes: blinking, random wandering and controlled cursor-following movement",
  "private": false,
  "type": "module",
  "main": "./dist/CartoonEyes.js",
  "types": "./src/CartoonEyes.d.ts",
  "exports": {
    ".": {
      "types": "./src/CartoonEyes.d.ts",
      "default": "./dist/CartoonEyes.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "keywords": [
    "react",
    "react-component",
    "svg",
    "svg-animation",
    "animation",
    "cartoon",
    "eye",
    "eyes",
    "animated-eyes",
    "blinking",
    "googly",
    "googly-eyes",
    "cursor-following",
    "mouse-follow",
    "eye-tracking",
    "mascot",
    "avatar"
  ],
  "scripts": {
    "build": "esbuild src/CartoonEyes.jsx --jsx=automatic --format=esm --outfile=dist/CartoonEyes.js",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tmrk/cartoon-eyes.git"
  },
  "author": "Tamas Marki",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tmrk/cartoon-eyes/issues"
  },
  "homepage": "https://tmrk.github.io/cartoon-eyes/",
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
